# recreates this dir on the remote. Retrieve with ./sync.sh pull results.
docs/phases/phase_1_stencil_core/step_1.1_results/
# Generated profiling output dir (benchmark.py default location).
2D/src/mcs2d/output/

# BSSN spill-probe XLA dump (regenerated each run)
bssn_xla_dump/
